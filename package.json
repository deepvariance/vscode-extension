{
  "name": "deepvariance-vscode",
  "version": "0.1.0",
  "description": "One-command setup for the Qwen3.5 27B coding assistant in VS Code's built-in Chat.",
  "type": "module",
  "bin": {
    "deepvariance-vscode": "dist/cli.js"
  },
  "files": [
    "dist",
    "extension/*.vsix"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "build:extension": "cd extension && npm install && npm run package",
    "test": "node --test test/*.test.js",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": false,
  "dependencies": {},
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "esbuild": "^0.24.0"
  }
}
